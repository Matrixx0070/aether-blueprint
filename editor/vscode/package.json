{
    "name": "aether",
    "displayName": "Aether",
    "description": "Agentic coding via aether — runs aether-cli as a child process, streams output into VS Code.",
    "version": "0.20.0",
    "publisher": "matrixx0070",
    "license": "Apache-2.0",
    "engines": {
        "vscode": "^1.85.0"
    },
    "main": "./out/extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/Matrixx0070/aether-blueprint.git",
        "directory": "editor/vscode"
    },
    "homepage": "https://github.com/Matrixx0070/aether-blueprint#readme",
    "bugs": {
        "url": "https://github.com/Matrixx0070/aether-blueprint/issues"
    },
    "keywords": [
        "ai",
        "agent",
        "claude",
        "coding-assistant",
        "anthropic",
        "llm"
    ],
    "categories": [
        "Programming Languages",
        "Other"
    ],
    "activationEvents": [],
    "contributes": {
        "commands": [
            {
                "command": "aether.ask",
                "title": "aether: Ask"
            },
            {
                "command": "aether.askAboutSelection",
                "title": "aether: Ask about selection"
            },
            {
                "command": "aether.doctor",
                "title": "aether: Doctor (health check)"
            },
            {
                "command": "aether.openChat",
                "title": "aether: Open chat panel"
            }
        ],
        "configuration": {
            "title": "aether",
            "properties": {
                "aether.binaryPath": {
                    "type": "string",
                    "default": "aether",
                    "description": "Path to the aether binary. Default uses $PATH lookup."
                },
                "aether.model": {
                    "type": "string",
                    "default": "",
                    "description": "Model override (e.g. claude-sonnet-4-6). Empty = aether's own default."
                },
                "aether.permissionMode": {
                    "type": "string",
                    "default": "default",
                    "enum": [
                        "default",
                        "acceptEdits",
                        "plan",
                        "bypassPermissions"
                    ],
                    "description": "Permission mode passed to `aether -p`. bypassPermissions allows aether to Edit/Write/Bash without prompting (use with care)."
                },
                "aether.serveUrl": {
                    "type": "string",
                    "default": "ws://127.0.0.1:7777/ws/chat",
                    "description": "WebSocket URL for the chat panel. Run `aether serve --bind 127.0.0.1:7777` separately."
                },
                "aether.serveToken": {
                    "type": "string",
                    "default": "",
                    "description": "Optional bearer token sent on the WS upgrade. Required only when the server was started with AETHER_SERVE_TOKEN set."
                }
            }
        },
        "menus": {
            "editor/context": [
                {
                    "command": "aether.askAboutSelection",
                    "group": "navigation@9"
                }
            ]
        }
    },
    "scripts": {
        "compile": "tsc -p .",
        "watch": "tsc -p . -w",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.0.0"
    }
}
